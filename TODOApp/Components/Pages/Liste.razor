


<input placeholder=@placeholdertext
       @bind="neuTaskName"
       @bind:event="oninput"
       @onkeydown="handelEnterkey" />
        
<button   @onclick="addTask"  >weitere aufgabe eingeben</button>
    
<table>
    <tr id="top-row">
        <th class="einleitung">Aufgaben / TODOs</th>   
        <th class="einleitung">Status</th>
    </tr>
    @foreach(var task in tasks)
    {
        <tr id="task-row">
            <td>@task.name</td>
            <td><input type="checkbox"
                       checked="@task.isDone"
                       @onchange="(e => OnTaskChecked(task , e))" 
                /></td>
        </tr>
    }
</table>
